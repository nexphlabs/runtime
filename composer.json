{
    "name": "nexph/runtime",
    "description": "Runtime core for Nexph framework",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Nexph\\Runtime\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "ext-pcntl": "*",
        "ext-posix": "*",
        "ext-pdo": "*",
        "nexph/core": "^0.0",
        "nexph/support": "^0.0",
        "nexph/observability": "^0.0"
    },
    "suggest": {
        "ext-apcu": "For runtime cache and APCu queue driver",
        "ext-redis": "For Redis queue, cache, and event bus"
    }
}

